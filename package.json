{
  "name": "valclassifieds",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:mock": "playwright test --config=tests/e2e/playwright.config.ts --project=mock",
    "test:e2e:real": "playwright test --config=tests/e2e/playwright.config.ts --project=e2e",
    "test:e2e:ui": "playwright test --ui-host=127.0.0.1 --ui-port=54000 --config=tests/e2e/playwright.config.ts",
    "test:e2e:debug": "playwright test --debug --config=tests/e2e/playwright.config.ts",
    "test:e2e:report": "allure generate allure-results --clean -o allure-report && echo Report generated to allure-report/index.html",
    "db:seed:auth": "node scripts/seed-auth.mjs",
    "db:seed:data": "node scripts/seed-data.mjs",
    "db:seed": "npm run db:seed:auth && npm run db:seed:data"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "date-fns": "^3.6.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.26.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.8.0",
    "eslint-plugin-playwright": "^2.10.4",
    "pg": "^8.22.0",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
